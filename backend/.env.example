# =============================================================================
# River Intelligence Platform - Environment Configuration Example
#
# Copy this file to `.env` and adjust values for your local machine.
# Nothing in the application should be hardcoded outside of this file
# and app/config/settings.py.
# =============================================================================

# --- Application metadata ---
APP_NAME=River Intelligence Platform
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# --- API / server configuration ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database configuration (PostgreSQL / TimescaleDB) ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/river_intelligence
DATABASE_PORT=5432
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# --- Serial / Arduino configuration ---
# Windows example: COM3   |   Linux example: /dev/ttyUSB0
# Set SERIAL_COM_PORT=auto together with SERIAL_AUTO_DETECT=true to
# have the backend auto-detect the Arduino's port.
SERIAL_COM_PORT=COM3
SERIAL_BAUD_RATE=9600
SAMPLING_INTERVAL_SECONDS=5
SERIAL_AUTO_DETECT=true
SERIAL_CONNECT_TIMEOUT_SECONDS=2.0
SERIAL_READ_TIMEOUT_SECONDS=1.0
SERIAL_RECONNECT_DELAY_SECONDS=5.0
SERIAL_MAX_RECONNECT_DELAY_SECONDS=30.0
SERIAL_MAX_LINE_BYTES=4096
SERIAL_QUEUE_MAX_SIZE=500

# --- Dashboard configuration ---
DASHBOARD_REFRESH_INTERVAL_SECONDS=5

# --- Logging configuration ---
LOG_FOLDER=logs
LOG_LEVEL=INFO
