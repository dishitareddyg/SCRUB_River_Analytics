# =============================================================================
# River Intelligence Platform - Frontend Environment Configuration Example
#
# Copy this file to `.env` (or `.env.local`) and adjust for your machine.
# Every variable consumed by the app is read through `import.meta.env`
# in src/api/api.js - nothing else in the app should read env vars
# directly, so this file stays the single source of truth.
#
# Vite only exposes variables prefixed with VITE_ to client code.
# =============================================================================

# Base URL of the FastAPI backend (no trailing slash, no /api/v1 suffix -
# that versioned prefix is appended automatically in src/api/api.js).
VITE_API_BASE_URL=http://localhost:8000

# How often the Live Dashboard and Analytics pages poll their endpoints,
# in seconds. The backend samples sensors on this same cadence by
# default, but this is purely a frontend display setting - the backend
# does not currently expose its own sampling interval over the API.
VITE_REFRESH_INTERVAL_SECONDS=5

# HTTP request timeout, in milliseconds.
VITE_API_TIMEOUT_MS=8000
